@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(falcon-database CONFIG REQUIRED)
find_dependency(falcon-comms CONFIG REQUIRED)
find_dependency(falcon-core CONFIG REQUIRED COMPONENTS c-api)
find_dependency(nlohmann_json CONFIG REQUIRED)
find_dependency(spdlog CONFIG REQUIRED)
find_dependency(cnats CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/falcon-routine-targets.cmake")

check_required_components(falcon-routine)
